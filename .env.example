# ─── Supabase ─────────────────────────────────────────────────
# Create a project at https://supabase.com, then copy these from
# Settings → API → Project URL / anon key / service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Drive ─────────────────────────────────────────────
# These are used as fallbacks for local development.
# In production, configure these in Settings → Advanced (stored in the database).
GOOGLE_SHARED_DRIVE_ID=your-shared-drive-id
SYNC_FOLDERS=Photo Library,Video Library

# ─── Google OAuth ─────────────────────────────────────────────
# Create OAuth 2.0 credentials in Google Cloud Console → APIs & Services → Credentials.
# These are the same credentials configured in Supabase Dashboard → Auth → Google provider.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Google Drive Labels (optional) ──────────────────────────
# Fallback for local dev. In production, set this in Settings → Advanced.
GOOGLE_DRIVE_LABEL_ID=

# ─── Gemini AI (optional) ────────────────────────────────────
# Powers semantic search via text embeddings and AI-assisted naming.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── GitHub Actions Sync (optional) ──────────────────────────
# Enables "Sync Now" button to trigger the daily-sync GitHub Actions workflow.
# Create a fine-grained PAT at https://github.com/settings/tokens with
# "Actions" read+write permission on your repository.
# GITHUB_TOKEN=ghp_your-token
# GITHUB_REPO=your-username/relay-asset-manager

# ─── Service Account (optional) ──────────────────────────────
# Set to 'true' to use Application Default Credentials (gcloud auth)
# instead of the logged-in user's OAuth token for Drive access.
USE_SERVICE_ACCOUNT=false

# ─── Vercel WIF — Production Only (optional) ─────────────────
# Workload Identity Federation for keyless GCP access from Vercel.
# Not needed for local development.
# VERCEL_TEAM_SLUG=your-team-slug          (from your Vercel dashboard URL)
# GCP_PROJECT_NUMBER=your-project-number
# GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GCP_WORKLOAD_IDENTITY_POOL_ID=your-pool-id
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=your-provider-id
